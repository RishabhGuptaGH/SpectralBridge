# Codeforces
SPECTRALBRIDGE_CF_API_BASE=https://codeforces.com/api

# LeetCode
SPECTRALBRIDGE_LC_GRAPHQL_URL=https://leetcode.com/graphql

# When true the service never calls external APIs (problems not in the bundled
# dataset return a 404 with suggestions instead of a live lookup).
SPECTRALBRIDGE_USE_FALLBACK_ONLY=false

# Comma-separated allowed CORS origins ("*" by default).
SPECTRALBRIDGE_CORS=*

# ML hyperparameters (defaults shown)
SPECTRALBRIDGE_LSA_COMPONENTS=150
SPECTRALBRIDGE_TAG_BOOST=6
SPECTRALBRIDGE_SPECTRAL_DIMS=64
SPECTRALBRIDGE_BRIDGE_LOWER=100
SPECTRALBRIDGE_BRIDGE_UPPER=300
SPECTRALBRIDGE_BRIDGE_TOP_K=3
